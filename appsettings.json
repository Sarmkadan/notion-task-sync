{
  "AppSettings": {
    "LocalTasksDirectory": "./tasks",
    "LogLevel": "Information",
    "EnableConsoleLogging": true,
    "DryRun": false,
    "LogFilePath": "./logs/notion-sync.log",
    "DefaultSyncIntervalSeconds": 300,
    // Accepted values: LastWrite | LocalWins | NotionWins | Manual
    "DefaultConflictStrategy": "LastWrite",
    "MaxConcurrentSyncs": 1,
    "EnableChangeTracking": true,
    "MaxRetries": 3,
    "ApiTimeoutSeconds": 30,
    "BackupDirectory": "./backups",
    "EnableAutoBackup": true,
    "BackupFrequencyHours": 24,
    "MaxBackupFiles": 10,
    "Version": "1.0.0",
    "Environment": "Development"
  },
  "NotionApi": {
    "ApiKey": "YOUR_NOTION_API_KEY_HERE",
    "BaseUrl": "https://api.notion.com/v1",
    "ApiVersion": "2022-06-28",
    "RequestTimeoutSeconds": 30,
    "MaxRetries": 3,
    "RetryDelayMs": 1000,
    "RateLimitPerMinute": 30,
    "RespectRateLimits": true,
    "DefaultPageSize": 100,
    "MaxPageSize": 100,
    "EnableCaching": true,
    "CacheDurationMinutes": 5,
    "DatabaseIds": [
      "YOUR_NOTION_DATABASE_ID_HERE"
    ],
    "PropertyMappings": {
      "Title": "Name",
      "Status": "Status",
      "Priority": "Priority",
      "DueDate": "Due Date"
    }
  },
  // Per-sync-profile configuration. Each profile maps to one Notion database.
  // conflictStrategy accepted values: LastWrite | LocalWins | NotionWins | Manual
  // fieldConflictStrategies overrides conflictStrategy for individual fields.
  "SyncProfiles": {
    "default": {
      "notionDatabaseId": "YOUR_NOTION_DATABASE_ID_HERE",
      "localFolderPath": "./tasks",
      "conflictStrategy": "LastWrite",
      "fieldConflictStrategies": {
        "Title": "LocalWins",
        "Status": "NotionWins"
      },
      "syncIntervalSeconds": 300,
      "ignoredFields": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
